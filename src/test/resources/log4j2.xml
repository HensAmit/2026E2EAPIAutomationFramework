<?xml version="1.0" encoding="UTF-8"?>
<!--
    log4j2.xml — placed in src/test/resources so it is on the test classpath.

    Two appenders:
      Console  — coloured output, DEBUG+ in dev, INFO+ in CI
      RollingFile — writes to target/logs/framework.log, rolls at 10MB / daily
-->
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <!-- Log pattern: timestamp | level | thread | logger (short) | message -->
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%t] %logger{36} - %msg%n
        </Property>
        <Property name="LOG_DIR">target/logs</Property>
    </Properties>

    <Appenders>

        <!-- Console appender with ANSI colour highlighting -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>

        <!-- Rolling file appender — rolls on size (10MB) or daily -->
        <RollingFile name="FileAppender"
                     fileName="${LOG_DIR}/framework.log"
                     filePattern="${LOG_DIR}/framework-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

    </Appenders>

    <Loggers>

        <!-- Framework loggers — DEBUG level to see request/response detail -->
        <Logger name="com.spotify.framework" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Test loggers -->
        <Logger name="com.spotify.tests" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- RestAssured — reduce noise; set to DEBUG if you need wire-level logs -->
        <Logger name="io.restassured" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <!-- Apache HttpClient (used by RestAssured internally) -->
        <Logger name="org.apache.http" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <!-- Root fallback -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>

    </Loggers>

</Configuration>
